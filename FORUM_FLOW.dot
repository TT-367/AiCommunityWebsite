digraph AiGoForumFlow {
  rankdir=LR;
  bgcolor="#0b0b0d";
  node [shape=box, style="rounded,filled", fontname="Segoe UI", fontsize=12, color="#3e3e48", fontcolor="#dfe0e5", fillcolor="#141418"];
  edge [color="#5a5a66", fontname="Segoe UI", fontsize=10, fontcolor="#c9cad1"];

  subgraph cluster_global {
    label="全站入口与全局导航";
    color="#3e3e48";
    fontcolor="#dfe0e5";
    H [label="Header 导航\n- Logo\n- 开发者社区\n- 资产商店\n- 最新活动\n- 用户中心", fillcolor="#101012"];
    FAB [label="浮动发帖按钮\n(仅 /, /games, /games/:id, /skills/:id)", fillcolor="#101012"];
  }

  subgraph cluster_home {
    label="首页 /（三种模式）";
    color="#3e3e48";
    fontcolor="#dfe0e5";
    HOME [label="/", fillcolor="#121216"];
    HUB [label="项目 Hub 视图\n无 project、无 tab"];
    TAB [label="社区 Tab 视图\n/?tab=hot|latest|skills|games\n可选：tags,q"];
    WF [label="工作流视图\n/?project=:projectId\n可选：stage=:stageId"];
    HOME -> HUB;
    HOME -> TAB;
    HOME -> WF;
  }

  subgraph cluster_hub {
    label="首页 · 项目 Hub 主要入口";
    color="#3e3e48";
    fontcolor="#dfe0e5";
    HUB_EVENTS [label="活动 Banner\n(点击进入活动页)"];
    HUB_QUICK [label="快速开始\n- 创建新项目\n- 我的资产库"];
    HUB_TPL [label="模板库\n(推荐 + 查看全部)"];
    HUB_GAMES [label="游戏空间\n(卡片 + 查看全部)"];
  }

  subgraph cluster_community {
    label="开发者社区（内容链路）";
    color="#3e3e48";
    fontcolor="#dfe0e5";
    FEED [label="Feed 帖子流\n(tab=hot/latest)", fillcolor="#16161a"];
    POST [label="/post/:id\n帖子详情", fillcolor="#121216"];
    USER [label="/user/:id\n用户主页", fillcolor="#121216"];
  }

  subgraph cluster_skills {
    label="技能 / 工具链";
    color="#3e3e48";
    fontcolor="#dfe0e5";
    SKILL_MARKET [label="技能市场\n(tab=skills)", fillcolor="#16161a"];
    SKILL [label="/skills/:id\n技能详情", fillcolor="#121216"];
    TOOLCHAIN [label="/toolchain\n工具链页", fillcolor="#121216"];
  }

  subgraph cluster_games {
    label="游戏相关";
    color="#3e3e48";
    fontcolor="#dfe0e5";
    GALLERY [label="/games\n游戏广场", fillcolor="#121216"];
    GAME [label="/games/:id\n游戏详情", fillcolor="#121216"];
  }

  subgraph cluster_assets {
    label="资产与模板";
    color="#3e3e48";
    fontcolor="#dfe0e5";
    STORE [label="/assets\n资产商店/模板库", fillcolor="#121216"];
    MYASSETS [label="/my-assets\n我的资产库（按项目）", fillcolor="#121216"];
  }

  subgraph cluster_events {
    label="活动";
    color="#3e3e48";
    fontcolor="#dfe0e5";
    EVENTS [label="/events\n活动列表", fillcolor="#121216"];
    EVENTSTATE [label="进入详情\nroute state: {eventId}\n或页面内选择", style="rounded,filled,dashed", fillcolor="#101012"];
  }

  H -> HOME;
  H -> TAB;
  H -> STORE;
  H -> EVENTS;
  H -> USER;

  HUB -> HUB_EVENTS;
  HUB -> HUB_QUICK;
  HUB -> HUB_TPL;
  HUB -> HUB_GAMES;

  HUB_EVENTS -> EVENTS [label="Link + state"];
  HUB_TPL -> STORE [label="查看全部"];
  HUB_GAMES -> GALLERY [label="查看全部"];
  HUB_GAMES -> GAME [label="点击卡片"];
  HUB_QUICK -> WF [label="创建新项目\n生成 projectId"];
  HUB_QUICK -> MYASSETS [label="进入我的资产库"];

  TAB -> FEED [label="tab=hot/latest"];
  FEED -> POST [label="点击帖子卡片"];
  POST -> USER [label="作者头像/名称"];

  TAB -> SKILL_MARKET [label="tab=skills"];
  SKILL_MARKET -> SKILL [label="进入详情"];
  SKILL -> FAB [label="可发帖"];

  TAB -> GALLERY [label="tab=games"];
  GALLERY -> GAME [label="点击卡片"];
  GAME -> FAB [label="可发帖"];

  STORE -> WF [label="新建项目（用于工作流）"];
  MYASSETS -> WF [label="进入工作流\n/?project=:projectId"];

  EVENTS -> EVENTSTATE;
  FAB -> POST [label="打开 PostComposer 弹层\n(不切换路由)"];
}

